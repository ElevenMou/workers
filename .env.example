# Supabase (service role — bypasses RLS)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

TEMP_DIR=/tmp/video_clipper

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# AI / Transcription
OPENAI_API_KEY=sk-...
WHISPER_MODEL=base
# Optional yt-dlp cookies when running under docker compose.
# Put an exported Netscape cookie file in ./secrets/youtube-cookies.local.txt,
# or override the directory/name below.
YTDLP_COOKIES_SECRET_DIR=./secrets
# Direct-process overrides (normally leave unset; docker compose wires these automatically).
YTDLP_COOKIES_SOURCE_FILE=
YTDLP_COOKIES_FILE=
# Residential proxy for yt-dlp (recommended for datacenter servers)
# Example: http://user:pass@proxy.example.com:port
YTDLP_PROXY=
# Multiple residential proxies for rotation/fallback (comma-separated)
# If one proxy gets blocked, the next one is tried automatically.
# Example: http://user:pass@proxy1:port,http://user:pass@proxy2:port
YTDLP_PROXY_LIST=

# Optional: Anthropic fallback for video analysis
ANTHROPIC_API_KEY=
OPENAI_ANALYZER_MODEL=gpt-4.1-mini
OPENAI_ANALYZER_FALLBACK_MODELS=gpt-4.1-mini,gpt-4.1
OPENAI_ANALYZER_SYNTHESIS_MODEL=gpt-4.1
OPENAI_ANALYZER_CHUNK_TARGET_SECONDS=480
OPENAI_ANALYZER_CHUNK_OVERLAP_SECONDS=30
OPENAI_ANALYZER_CHUNK_MAX_CHARS=12000
OPENAI_ANALYZER_CANDIDATES_PER_CHUNK=4
CLAUDE_ANALYZER_MODEL=claude-4-5-haiku-latest
CLAUDE_ANALYZER_FALLBACK_MODELS=claude-4-5-haiku-latest,claude-3-5-haiku-latest

# Worker configuration
NUM_VIDEO_WORKERS=2
NUM_CLIP_WORKERS=2
NUM_SOCIAL_WORKERS=1
SUPERVISOR_ROLE=worker
VIDEO_JOB_TIMEOUT=1800    # max seconds per video analysis job (30 min)
CLIP_JOB_TIMEOUT=1800      # max seconds per clip generation job (30 min)

# CORS (comma-separated frontend URLs — REQUIRED for production)
# Example: https://clipscut.pro,https://www.clipscut.pro
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Optional regex for origin matching (e.g. for preview deploys)
CORS_ALLOWED_ORIGIN_REGEX=

# Logging & monitoring
LOG_FORMAT=human
SENTRY_DSN=

# Set to "production" or "prod" to enforce strict CORS
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
# Set MEDIA_STORAGE_PROVIDER=minio to enable.
# MINIO_ENDPOINT — Internal endpoint for worker-to-MinIO traffic (host:port, no scheme).
#   Docker Compose default: minio:9000. Local dev: localhost:9000.
MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY — Must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# MINIO_SECURE — Use TLS for the internal endpoint. Default: false.
MINIO_SECURE=false
# MINIO_PUBLIC_ENDPOINT — Browser-reachable URL for presigned URLs (include scheme).
#   Production example: https://cdn.clipscut.pro  Dev: http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
# Bucket names (defaults shown — override only if customized in MinIO)
# MINIO_AVATARS_BUCKET=avatars
# MINIO_LAYOUTS_BUCKET=layouts

# Admin: comma-separated Supabase user IDs allowed to scale workers
WORKER_SCALE_ADMIN_USER_IDS=

# Social publishing (required for social-workers)
SOCIAL_ACCOUNT_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=

# ---------------------------------------------------------------------------
# Horizontal Scaling (Caddy + API replicas)
# ---------------------------------------------------------------------------
#
# CADDY_DOMAIN — Domain Caddy listens on. It auto-provisions Let's Encrypt
#   TLS for real domains. Leave unset (or "localhost:8080") for local dev.
#   Production example: api.clipscut.pro
CADDY_DOMAIN=localhost:8080
#
# API_REPLICAS — Number of API containers behind Caddy.
#   Total API concurrency = API_REPLICAS × API_WORKERS.
#   Default: 1 (local dev). Production recommendation: 3.
API_REPLICAS=1
#
# API_WORKERS — Gunicorn worker processes *per* API container.
#   With multiple replicas, reduce this to avoid over-provisioning.
#   Default: 2. Local single-container dev can use 4.
API_WORKERS=2
#
# API_REDIS_MAX_CONNECTIONS — Max Redis connections per API replica.
#   Keep this low when running many replicas to stay within Redis budget.
#   Total API Redis connections = API_REPLICAS × API_WORKERS × API_REDIS_MAX_CONNECTIONS
#   Default: 15.
API_REDIS_MAX_CONNECTIONS=15
#
# Redis connection budget (approximate):
#   API:          API_REPLICAS(3) × API_WORKERS(2) × API_REDIS_MAX_CONNECTIONS(15) =  90
#   Video wkrs:   80
#   Clip wkrs:    80
#   Social wkrs:  40
#   Maintenance:  40
#   ─────────────────────────────────────────────────────────────
#   Total:       ~330  (Redis default maxclients = 10000, plenty of headroom)
#
# REDIS_MAX_CONNECTIONS — Default pool size for non-API services (workers,
#   maintenance). No need to change unless you scale worker replicas too.
REDIS_MAX_CONNECTIONS=40
