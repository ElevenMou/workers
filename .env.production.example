# Clipry Workers - Production Environment
# Copy this file to .env and fill in all values before deploying.

ENVIRONMENT=production

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password

# AI / transcription
OPENAI_API_KEY=sk-...
WHISPER_MODEL=base
YTDLP_COOKIES_SOURCE_FILE=/run/secrets/youtube-cookies.txt
YTDLP_COOKIES_FILE=/tmp/video_clipper/yt-dlp/cookies.txt
YTDLP_COOKIES_SECRET_DIR=./secrets
YTDLP_PROXY=
YTDLP_PROXY_LIST=
ANTHROPIC_API_KEY=
OPENAI_ANALYZER_MODEL=gpt-4.1-mini
OPENAI_ANALYZER_FALLBACK_MODELS=gpt-4.1-mini,gpt-4.1
OPENAI_ANALYZER_SYNTHESIS_MODEL=gpt-4.1
OPENAI_ANALYZER_CHUNK_TARGET_SECONDS=480
OPENAI_ANALYZER_CHUNK_OVERLAP_SECONDS=30
OPENAI_ANALYZER_CHUNK_MAX_CHARS=12000
OPENAI_ANALYZER_CANDIDATES_PER_CHUNK=4
CLAUDE_ANALYZER_MODEL=claude-4-5-haiku-latest
CLAUDE_ANALYZER_FALLBACK_MODELS=claude-4-5-haiku-latest,claude-3-5-haiku-latest

# Worker concurrency
NUM_VIDEO_WORKERS=4
NUM_CLIP_WORKERS=4
NUM_SOCIAL_WORKERS=3
VIDEO_JOB_TIMEOUT=1800
CLIP_JOB_TIMEOUT=1800
SOCIAL_JOB_TIMEOUT=1800
FFMPEG_THREADS=2
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1

# CORS
CORS_ALLOWED_ORIGINS=https://clipscut.pro,https://www.clipscut.pro
CORS_ALLOWED_ORIGIN_REGEX=^https://clipscut-.*\\.vercel\\.app$

# Caddy / API scaling
CADDY_DOMAIN=api.clipscut.pro
API_REPLICAS=2
API_WORKERS=4
API_REDIS_MAX_CONNECTIONS=15

# Worker URLs / internal auth
WORKER_PUBLIC_BASE_URL=https://api.clipscut.pro
WORKER_MEDIA_SIGNING_SECRET=replace-with-worker-media-signing-secret
WORKER_INTERNAL_API_TOKEN=replace-with-worker-internal-token

# MinIO object storage
MEDIA_STORAGE_PROVIDER=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=https://storage.clipscut.pro
MINIO_REGION=us-east-1
MINIO_CLIPS_BUCKET=generated-clips
MINIO_RAW_VIDEOS_BUCKET=raw-videos
MINIO_AVATARS_BUCKET=avatars
MINIO_LAYOUTS_BUCKET=layouts

# Admin
WORKER_SCALE_ADMIN_USER_IDS=replace-with-supabase-user-id

# Logging & monitoring
LOG_FORMAT=json
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production

# Social publishing
SOCIAL_ACCOUNT_ENCRYPTION_KEY=replace-with-base64-32-byte-key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_PREFER_PULL_FROM_URL=false
TIKTOK_VERIFIED_SOURCE_URL_PREFIXES=
META_APP_ID=
META_APP_SECRET=

# Docker resource limits (optional)
# CADDY_CPU_LIMIT=0.5
# CADDY_MEM_LIMIT=256m
# REDIS_CPU_LIMIT=0.5
# REDIS_MEM_LIMIT=1g
# API_CPU_LIMIT=1.5
# API_MEM_LIMIT=1g
# VIDEO_WORKERS_CPU_LIMIT=3.5
# VIDEO_WORKERS_MEM_LIMIT=6g
# CLIP_WORKERS_CPU_LIMIT=3.5
# CLIP_WORKERS_MEM_LIMIT=6g
# SOCIAL_WORKERS_CPU_LIMIT=1
# SOCIAL_WORKERS_MEM_LIMIT=1g
# MAINTENANCE_CPU_LIMIT=0.5
# MAINTENANCE_MEM_LIMIT=512m
