# Clipry Workers — Production Environment
# Copy this file to .env and fill in all values before deploying.
# Generate secrets with: openssl rand -base64 32

# ---- Core ----
ENVIRONMENT=production

# ---- Supabase (service role — bypasses RLS) ----
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_openssl_rand_base64_32

# ---- AI / Transcription ----
OPENAI_API_KEY=sk-...
WHISPER_MODEL=base
YTDLP_COOKIES_SOURCE_FILE=/run/secrets/youtube-cookies.local.txt
YTDLP_COOKIES_FILE=/tmp/video_clipper/yt-dlp/cookies.txt
OPENAI_ANALYZER_MODEL=gpt-4.1-mini
OPENAI_ANALYZER_FALLBACK_MODELS=gpt-4.1-mini,gpt-4.1
OPENAI_ANALYZER_SYNTHESIS_MODEL=gpt-4.1
OPENAI_ANALYZER_CHUNK_TARGET_SECONDS=480
OPENAI_ANALYZER_CHUNK_OVERLAP_SECONDS=30
OPENAI_ANALYZER_CHUNK_MAX_CHARS=12000
OPENAI_ANALYZER_CANDIDATES_PER_CHUNK=4

# Optional yt-dlp cookies for docker compose.
# Place the exported Netscape cookie file in ./secrets/youtube-cookies.local.txt,
# or point these at a different directory/file on the host.
YTDLP_COOKIES_SECRET_DIR=./secrets
YTDLP_COOKIES_SECRET_FILE=youtube-cookies.local.txt

# YouTube bot-check bypass — residential proxies with rotation/fallback
YTDLP_PROXY=
# Comma-separated list of proxies (tried in order if one gets blocked)
YTDLP_PROXY_LIST=

# Optional: Anthropic as fallback analyzer
ANTHROPIC_API_KEY=
CLAUDE_ANALYZER_MODEL=claude-4-5-haiku-latest
CLAUDE_ANALYZER_FALLBACK_MODELS=claude-4-5-haiku-latest,claude-3-5-haiku-latest

# ---- Worker concurrency ----
# Tune based on VPS resources. Each video worker loads Whisper (~500MB RAM).
NUM_VIDEO_WORKERS=4
NUM_CLIP_WORKERS=4
NUM_SOCIAL_WORKERS=3
VIDEO_JOB_TIMEOUT=1800
CLIP_JOB_TIMEOUT=1800
SOCIAL_JOB_TIMEOUT=1800
FFMPEG_THREADS=2
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1

# ---- Docker resource limits ----
# Adjust based on your server's CPU/RAM. Values must not exceed available CPUs.
# CADDY_CPU_LIMIT=0.5
# CADDY_MEM_LIMIT=256m
# REDIS_CPU_LIMIT=0.5
# REDIS_MEM_LIMIT=1g
# API_CPU_LIMIT=1.5
# API_MEM_LIMIT=1g
# VIDEO_WORKERS_CPU_LIMIT=3.5
# VIDEO_WORKERS_MEM_LIMIT=6g
# CLIP_WORKERS_CPU_LIMIT=3.5
# CLIP_WORKERS_MEM_LIMIT=6g
# SOCIAL_WORKERS_CPU_LIMIT=1
# SOCIAL_WORKERS_MEM_LIMIT=1g
# MAINTENANCE_CPU_LIMIT=0.5
# MAINTENANCE_MEM_LIMIT=512m

# ---- CORS (required for production) ----
CORS_ALLOWED_ORIGINS=https://clipscut.pro,https://www.clipscut.pro
CORS_ALLOWED_ORIGIN_REGEX=^https://clipry-.*\.vercel\.app$

# ---- Caddy (TLS + load balancer) ----
# Set to your API domain. Caddy auto-provisions Let's Encrypt TLS.
CADDY_DOMAIN=api.clipscut.pro
API_REPLICAS=2
API_WORKERS=4
API_REDIS_MAX_CONNECTIONS=15

# ---- Admin ----
WORKER_SCALE_ADMIN_USER_IDS=your-supabase-user-id

# ---- Logging & Monitoring ----
LOG_FORMAT=json
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production

# ---- Social publishing ----
SOCIAL_ACCOUNT_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
