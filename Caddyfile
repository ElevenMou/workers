# Clipry Workers API — Caddy reverse proxy for local development and
# Cloudflare Tunnel-backed production.
#
# Tunnel-backed deployments should set CADDY_DOMAIN to ":7050" and route
# api.clipscut.pro -> http://127.0.0.1:7050 with cloudflared.
# Direct Caddy TLS requires exposing 80/443 and setting CADDY_DOMAIN to the
# public API hostname instead.

{$CADDY_DOMAIN:localhost:7050} {
	reverse_proxy api:8001 {
		lb_policy round_robin

		health_uri /ready
		health_interval 10s
		health_timeout 5s
	}

	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format json
	}
}
